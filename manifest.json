{
  "manifest_version": 3,
  "name": "JustDump",
  "version": "1.0.0",
  "description": "AI-powered knowledge archive. Save, organize, and rediscover web content.",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": { "page": "settings.html", "open_in_tab": true },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "host_permissions": [
    "https://*.googleapis.com/*",
    "https://*.supabase.co/*"
  ]
}
