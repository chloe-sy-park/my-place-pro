{
  "manifest_version": 3,
  "name": "JustDump",
  "version": "1.4",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": { "default_popup": "popup.html" },
  "options_ui": { "page": "dashboard.html", "open_in_tab": true },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "host_permissions": ["https://*.googleapis.com/*"]
}
