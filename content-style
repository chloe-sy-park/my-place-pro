#mm-pin-btn {
  position: absolute; z-index: 2147483647; padding: 8px 16px;
  background: #6366f1; color: white; border: none; border-radius: 30px;
  font-family: sans-serif; font-size: 13px; font-weight: 800; cursor: pointer;
  box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4); display: none; align-items: center; gap: 8px;
}
#mm-pin-btn:hover { background: #4f46e5; transform: translateY(-2px); }
#mm-pin-btn.saved { background: #10b981; }
